PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/finpilot?retryWrites=true&w=majority

# JWT
JWT_ACCESS_SECRET=replace-with-access-secret
JWT_REFRESH_SECRET=replace-with-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# App URLs
CLIENT_URL=http://localhost:5173
VITE_API_URL=http://localhost:5000/api
ADDITIONAL_CORS_ORIGINS=http://localhost:5173

# Google auth
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Stripe billing
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_PRICE_ID_PRO=replace-with-stripe-price-id
STRIPE_TRIAL_DAYS=0
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=replace-with-stripe-publishable-key

# Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=replace-with-email-user
SMTP_PASS=replace-with-email-pass
SMTP_FROM=FinPilot AI <replace-with-email-user>

# AI providers
GROQ_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=replace-with-groq-api-key
GEMINI_MODEL=gemini-1.5-pro
